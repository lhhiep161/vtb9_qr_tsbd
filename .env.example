# Frontend API base URL for Capacitor/static build.
# Leave empty to use same-origin (web served by backend).
GEOQR_API_BASE_URL=

# Backend CORS origins (comma-separated).
# Example:
# CORS_ALLOW_ORIGINS=https://your-web-domain.com,https://www.your-web-domain.com,capacitor://localhost,http://localhost
CORS_ALLOW_ORIGINS=
